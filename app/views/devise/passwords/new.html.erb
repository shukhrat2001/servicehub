<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">

  <div class="w-full max-w-md">

    <div class="card p-8">

      <!-- Header -->
      <div class="text-center mb-6">
        <h1 class="text-2xl font-semibold text-gray-900">
          Forgot your password?
        </h1>
        <p class="text-sm text-gray-500 mt-2">
          Enter your email and we’ll send you a reset link
        </p>
      </div>

      <!-- Flash messages (IMPORTANT) -->
      <% if notice %>
        <p class="mb-4 text-sm text-green-600 text-center"><%= notice %></p>
      <% end %>

      <% if alert %>
        <p class="mb-4 text-sm text-red-600 text-center"><%= alert %></p>
      <% end %>

      <!-- Devise form (THIS is the fix) -->
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>

          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <%= f.submit "Send reset link", class: "btn btn-primary w-full" %>

      <% end %>

      <!-- Links -->
      <div class="mt-6 text-center text-sm text-gray-600 space-y-2">

        <div>
          Remember your password?
          <%= link_to "Log in", new_session_path(resource_name), class: "text-blue-600 hover:underline" %>
        </div>

        <div>
          Don’t have an account?
          <%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-600 hover:underline" %>
        </div>

      </div>

    </div>

  </div>
</div>