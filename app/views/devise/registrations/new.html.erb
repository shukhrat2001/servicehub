<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 px-4">

  <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-slate-200 p-8">

    <!-- Header -->
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold text-slate-900">Create your account</h2>
      <p class="text-slate-500 mt-2">Join ServiceHub in seconds</p>
    </div>

    <!-- Form -->
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <!-- Error messages -->
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- Email -->
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" %>
      </div>

      <!-- Password -->
      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>

        <% if @minimum_password_length %>
          <p class="text-xs text-slate-500 mb-1">
            <%= @minimum_password_length %> characters minimum
          </p>
        <% end %>

        <%= f.password_field :password,
              autocomplete: "new-password",
              class: "w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" %>
      </div>

      <!-- Password confirmation -->
      <div class="mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" %>
      </div>

      <!-- Submit -->
      <div>
        <%= f.submit "Create account",
              class: "w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition shadow-md hover:shadow-lg" %>
      </div>

    <% end %>

    <!-- Links -->
    <div class="mt-6 text-center text-sm text-slate-500 space-y-2">

      <%= render "devise/shared/links" %>

    </div>

  </div>
</div>