<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-12 px-4">

  <div class="max-w-2xl mx-auto bg-white border border-slate-200 rounded-2xl shadow-lg p-8">

    <h1 class="text-3xl font-bold text-slate-900 mb-6">
      Create New Service
    </h1>

    <%= form_with model: @service, class: "space-y-5" do |f| %>

      <% if @service.errors.any? %>
        <div class="p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm">
          <ul class="list-disc pl-5">
            <% @service.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Name -->
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name,
              class: "w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none" %>
      </div>

      <!-- Description -->
      <div>
        <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :description,
              rows: 4,
              class: "w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none" %>
      </div>

      <!-- Category -->
      <div>
        <%= f.label :category, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :category,
              class: "w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none" %>
      </div>

      <!-- Price -->
      <div>
        <%= f.label :base_price, "Price ($)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :base_price,
              class: "w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none" %>
      </div>

      <!-- Duration -->
      <div>
        <%= f.label :duration_minutes, "Duration (minutes)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :duration_minutes,
              class: "w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none" %>
      </div>

      <!-- Submit -->
      <div>
        <%= f.submit "Create Service",
              class: "w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition shadow-md" %>
      </div>

    <% end %>

  </div>

</div>