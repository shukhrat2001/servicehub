<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-12 px-4">

  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">

      <div>
        <h1 class="text-4xl font-bold text-slate-900">Services</h1>
        <p class="text-slate-600 mt-2">Browse available services from trusted providers</p>
      </div>

      <%= link_to "Post Service",
          new_service_path,
          class: "px-5 py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition shadow-md text-center" %>

    </div>

    <!-- Grid -->
    <% if @services.any? %>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <% @services.each do |service| %>

          <div class="bg-white border border-slate-200 rounded-2xl shadow-sm hover:shadow-xl transition overflow-hidden">

            <!-- Image -->
            <div class="h-40 bg-gradient-to-br from-emerald-100 to-teal-100 flex items-center justify-center">
              <span class="text-emerald-600 font-semibold">
                <%= service.category %>
              </span>
            </div>

            <!-- Content -->
            <div class="p-6 space-y-3">

              <h3 class="text-xl font-bold text-slate-900">
                <%= service.name %>
              </h3>

              <p class="text-sm text-slate-600 line-clamp-2">
                <%= service.description %>
              </p>

              <!-- Meta -->
              <div class="flex items-center justify-between pt-4 border-t border-slate-200">

                <div>
                  <p class="text-emerald-600 font-bold text-lg">
                    $<%= service.base_price %>
                  </p>
                  <p class="text-xs text-slate-500">
                    <%= service.duration_minutes %> min
                  </p>
                </div>

                <%= link_to "View",
                    service_path(service),
                    class: "px-4 py-2 bg-slate-900 text-white rounded-lg hover:bg-slate-800 transition text-sm" %>

              </div>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <!-- EMPTY STATE -->
      <div class="bg-white border border-slate-200 rounded-2xl p-16 text-center shadow-sm">

        <div class="text-6xl mb-4">🛠️</div>

        <h2 class="text-2xl font-bold text-slate-900 mb-2">
          No services available yet
        </h2>

        <p class="text-slate-600 mb-6">
          Be the first to post a service and start earning from your skills.
        </p>

        <%= link_to "Create First Service",
            new_service_path,
            class: "inline-block px-6 py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition" %>

      </div>

    <% end %>

  </div>

</div>