<div class="space-y-8">

  <div>
    <h1 class="text-3xl font-bold mb-6">Dashboard</h1>
  </div>

  <!-- Quick Stats -->
  <div class="grid grid-cols-3 gap-4">
    <div class="bg-white border border-slate-200 rounded-lg p-6">
      <p class="text-slate-600 text-sm">Bookings Made</p>
      <p class="text-3xl font-bold mt-2"><%= @customer_bookings.count %></p>
    </div>

    <div class="bg-white border border-slate-200 rounded-lg p-6">
      <p class="text-slate-600 text-sm">Bookings Received</p>
      <p class="text-3xl font-bold mt-2"><%= @provider_bookings.count %></p>
    </div>

    <div class="bg-white border border-slate-200 rounded-lg p-6">
      <p class="text-slate-600 text-sm">Messages</p>
      <p class="text-3xl font-bold mt-2"><%= @received_messages.count + @sent_messages.count %></p>
    </div>
  </div>

  <!-- Recent Bookings as Customer -->
  <div class="bg-white border border-slate-200 rounded-lg p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-bold">Recent Bookings (as Customer)</h2>
      <%= link_to "View All", dashboard_bookings_path, class: "text-sm text-teal-600 hover:text-teal-700" %>
    </div>

    <% if @customer_bookings.any? %>
      <div class="space-y-3">
        <% @customer_bookings.limit(5).each do |booking| %>
          <div class="flex justify-between items-center p-3 bg-slate-50 rounded-lg">
            <div>
              <p class="font-semibold"><%= booking.service.name %></p>
              <p class="text-sm text-slate-600"><%= booking.service.user.full_name %></p>
            </div>
            <div class="text-right">
              <span class="px-3 py-1 rounded text-white text-sm
                <%= case booking.status
                    when 'confirmed' then 'bg-green-600'
                    when 'pending' then 'bg-yellow-600'
                    when 'cancelled' then 'bg-red-600'
                    else 'bg-gray-600'
                    end %>">
                <%= booking.status.capitalize %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-600">No bookings yet</p>
    <% end %>
  </div>

  <!-- Recent Bookings as Provider -->
  <div class="bg-white border border-slate-200 rounded-lg p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-bold">Bookings for Your Services</h2>
      <%= link_to "View All", dashboard_bookings_path, class: "text-sm text-teal-600 hover:text-teal-700" %>
    </div>

    <% if @provider_bookings.any? %>
      <div class="space-y-3">
        <% @provider_bookings.limit(5).each do |booking| %>
          <div class="flex justify-between items-center p-3 bg-slate-50 rounded-lg">
            <div>
              <p class="font-semibold"><%= booking.service.name %></p>
              <p class="text-sm text-slate-600"><%= booking.customer.full_name %></p>
            </div>
            <div class="text-right">
              <span class="px-3 py-1 rounded text-white text-sm
                <%= case booking.status
                    when 'confirmed' then 'bg-green-600'
                    when 'pending' then 'bg-yellow-600'
                    when 'cancelled' then 'bg-red-600'
                    else 'bg-gray-600'
                    end %>">
                <%= booking.status.capitalize %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-600">No bookings for your services yet</p>
    <% end %>
  </div>

</div>
