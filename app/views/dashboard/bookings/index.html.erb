<div class="space-y-8">

  <h1 class="text-3xl font-bold">My Bookings</h1>

  <!-- Bookings as Customer -->
  <div>
    <h2 class="text-xl font-bold mb-4">Bookings I've Made</h2>
    
    <% if @customer_bookings.any? %>
      <div class="space-y-3">
        <% @customer_bookings.each do |booking| %>
          <div class="bg-white border border-slate-200 rounded-lg p-4 hover:shadow-md transition">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-semibold"><%= booking.service.name %></p>
                <p class="text-sm text-slate-600">Provider: <%= booking.service.user.full_name %></p>
                <% if booking.booking_date %>
                  <p class="text-sm text-slate-600 mt-1">Date: <%= booking.booking_date.strftime("%b %d, %Y at %I:%M %p") %></p>
                <% end %>
              </div>
              <div class="text-right">
                <span class="px-3 py-1 rounded text-white text-sm block mb-2
                  <%= case booking.status
                      when 'confirmed' then 'bg-green-600'
                      when 'pending' then 'bg-yellow-600'
                      when 'cancelled' then 'bg-red-600'
                      else 'bg-gray-600'
                      end %>">
                  <%= booking.status.capitalize %>
                </span>
                <%= link_to "View", dashboard_booking_path(booking), class: "text-sm text-teal-600 hover:text-teal-700" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-600">No bookings yet. <%= link_to "Browse services", services_path, class: "text-teal-600 hover:text-teal-700" %></p>
    <% end %>
  </div>

  <!-- Bookings as Provider -->
  <div class="border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold mb-4">Bookings for My Services</h2>
    
    <% if @provider_bookings.any? %>
      <div class="space-y-3">
        <% @provider_bookings.each do |booking| %>
          <div class="bg-white border border-slate-200 rounded-lg p-4 hover:shadow-md transition">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-semibold"><%= booking.service.name %></p>
                <p class="text-sm text-slate-600">Customer: <%= booking.customer.full_name %></p>
                <% if booking.booking_date %>
                  <p class="text-sm text-slate-600 mt-1">Date: <%= booking.booking_date.strftime("%b %d, %Y at %I:%M %p") %></p>
                <% end %>
              </div>
              <div class="text-right">
                <span class="px-3 py-1 rounded text-white text-sm block mb-2
                  <%= case booking.status
                      when 'confirmed' then 'bg-green-600'
                      when 'pending' then 'bg-yellow-600'
                      when 'cancelled' then 'bg-red-600'
                      else 'bg-gray-600'
                      end %>">
                  <%= booking.status.capitalize %>
                </span>
                <%= link_to "View", dashboard_booking_path(booking), class: "text-sm text-teal-600 hover:text-teal-700" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-600">No bookings for your services yet</p>
    <% end %>
  </div>

</div>
