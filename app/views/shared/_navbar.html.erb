<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">

    <!-- Logo -->
    <%= link_to root_path, class: "text-xl font-bold text-emerald-600" do %>
      ServiceHub
    <% end %>

    <!-- Links -->
    <div class="flex items-center gap-6 text-sm">

      <%= link_to "Browse",
          services_path,
          class: "text-slate-600 hover:text-slate-900 transition" %>

      <% if user_signed_in? %>

        <!-- User email -->
        <span class="text-slate-400 hidden sm:block">
          <%= current_user.email %>
        </span>

        <!-- Logout (SAFE FOR RAILS 8 + TURBO) -->
        <%= button_to "Logout",
              destroy_user_session_path,
              method: :delete,
              class: "text-red-600 hover:text-red-800 transition bg-transparent border-0 p-0 cursor-pointer" %>

      <% else %>

        <%= link_to "Login",
            new_user_session_path,
            class: "text-slate-600 hover:text-slate-900 transition" %>

        <%= link_to "Sign up",
            new_user_registration_path,
            class: "px-3 py-1.5 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition" %>

      <% end %>

    </div>
  </div>
</nav>