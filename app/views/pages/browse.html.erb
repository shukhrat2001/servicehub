<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-12 px-4">

  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900">
        Browse Services
      </h1>
      <p class="mt-3 text-slate-600 text-lg">
        Discover trusted professionals in your area
      </p>
    </div>

    <!-- Search Bar -->
    <div class="bg-white rounded-2xl shadow-md border border-slate-200 p-4 mb-10 flex flex-col md:flex-row gap-4">

      <input
        type="text"
        placeholder="Search services (cleaning, tutoring, repair...)"
        class="flex-1 px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none"
      />

      <select class="px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-emerald-500">
        <option>All Categories</option>
        <option>Cleaning</option>
        <option>Tutoring</option>
        <option>Repair</option>
        <option>Delivery</option>
      </select>

      <button class="px-6 py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition">
        Search
      </button>

    </div>

    <!-- Feature Cards / Quick Categories -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">

      <% [
        { title: "Home Services", desc: "Cleaning, repairs, maintenance" },
        { title: "Education", desc: "Tutors, coaching, courses" },
        { title: "Business Help", desc: "Design, marketing, tech support" }
      ].each do |item| %>

        <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-lg transition">

          <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center mb-4">
            <div class="w-5 h-5 bg-emerald-600 rounded"></div>
          </div>

          <h3 class="text-lg font-semibold text-slate-900 mb-2">
            <%= item[:title] %>
          </h3>

          <p class="text-slate-600 text-sm">
            <%= item[:desc] %>
          </p>

        </div>

      <% end %>

    </div>

    <!-- CTA Section -->
    <div class="bg-white border border-slate-200 rounded-2xl p-10 text-center shadow-sm">

      <h2 class="text-2xl font-bold text-slate-900 mb-2">
        Can't find what you're looking for?
      </h2>

      <p class="text-slate-600 mb-6">
        Post a request and let providers come to you
      </p>

      <a href="/services"
         class="inline-block px-6 py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition">
        Browse All Services
      </a>

    </div>

  </div>

</div>