<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Service Marketplace - Connect with trusted professionals">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-slate-50 text-slate-900 antialiased">

    <div class="min-h-full flex flex-col">

      <!-- NAVBAR -->
      <%= render "shared/navbar" %>

      <!-- FLASH -->
      <div class="max-w-7xl mx-auto w-full px-4 pt-4 space-y-2">
        <% if notice.present? %>
          <div class="p-3 rounded-lg bg-emerald-50 text-emerald-700 text-sm border border-emerald-200">
            <%= notice %>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="p-3 rounded-lg bg-red-50 text-red-700 text-sm border border-red-200">
            <%= alert %>
          </div>
        <% end %>
      </div>

      <!-- PAGE CONTENT -->
      <main class="flex-1">
        <%= yield %>
      </main>

      <!-- FOOTER -->
      <%= render "shared/footer" %>

    </div>

  </body>
</html>