<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Service Marketplace Dashboard">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application.tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "app", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-full flex">
      <!-- Sidebar -->
      <aside class="w-64 bg-white border-r border-slate-200">
        <div class="p-6">
          <h1 class="text-2xl font-bold text-teal-600 mb-8">
            <%= link_to "ServiceHub", dashboard_root_path %>
          </h1>

          <nav class="space-y-2">
            <div>
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Menu</p>
              <%= link_to "Dashboard", dashboard_root_path, class: "block px-4 py-2 rounded-lg hover:bg-slate-100 transition" %>
              <%= link_to "My Bookings", dashboard_bookings_path, class: "block px-4 py-2 rounded-lg hover:bg-slate-100 transition" %>
              <%= link_to "Messages", dashboard_messages_path, class: "block px-4 py-2 rounded-lg hover:bg-slate-100 transition" %>
            </div>

            <div class="pt-4 border-t border-slate-200">
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Account</p>
              <%= link_to "My Services", services_path, class: "block px-4 py-2 rounded-lg hover:bg-slate-100 transition" %>
              <%= link_to "Profile", edit_user_registration_path, class: "block px-4 py-2 rounded-lg hover:bg-slate-100 transition" %>
              <%= link_to "Sign Out", destroy_user_session_path, method: :delete, class: "block px-4 py-2 rounded-lg hover:bg-slate-100 transition text-red-600" %>
            </div>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-auto">
        <!-- Top Bar -->
        <div class="bg-white border-b border-slate-200 px-8 py-4">
          <div class="flex justify-between items-center">
            <h2 class="text-xl font-semibold"><%= current_user.full_name %></h2>
            <%= link_to "← Back to Browse", services_path, class: "text-sm text-teal-600 hover:text-teal-700" %>
          </div>
        </div>

        <!-- Flash Messages -->
        <div class="px-8 py-4 space-y-2">
          <% if notice.present? %>
            <div class="p-3 rounded-lg bg-emerald-50 text-emerald-700 text-sm border border-emerald-200">
              <%= notice %>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="p-3 rounded-lg bg-red-50 text-red-700 text-sm border border-red-200">
              <%= alert %>
            </div>
          <% end %>
        </div>

        <!-- Page Content -->
        <div class="px-8 py-8">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
