<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Service Marketplace Dashboard">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application.tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "app", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-slate-100 min-h-screen">
    <div class="flex h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-slate-950 border-r border-slate-700 flex flex-col">
        <div class="p-6 border-b border-slate-700">
          <h1 class="text-2xl font-bold bg-gradient-to-r from-teal-400 to-cyan-400 bg-clip-text text-transparent">
            <%= link_to "ServiceHub", dashboard_root_path %>
          </h1>
        </div>

        <nav class="flex-1 p-6 space-y-1 overflow-y-auto">
          <!-- Main Menu -->
          <div class="mb-8">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Navigation</p>
            <div class="space-y-1">
              <%= link_to dashboard_root_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition group" do %>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 16l-7-4m0 0V5m7 4l7-4" />
                </svg>
                <span class="group-hover:text-teal-400">Dashboard</span>
              <% end %>

              <%= link_to dashboard_bookings_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition group" do %>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <span class="group-hover:text-teal-400">My Bookings</span>
              <% end %>

              <%= link_to dashboard_messages_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition group" do %>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="group-hover:text-teal-400">Messages</span>
              <% end %>
            </div>
          </div>

          <!-- Account Section -->
          <div class="pt-8 border-t border-slate-700">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Account</p>
            <div class="space-y-1">
              <%= link_to services_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition group" do %>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <span class="group-hover:text-teal-400">My Services</span>
              <% end %>

              <%= link_to edit_user_registration_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition group" do %>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="group-hover:text-teal-400">Profile</span>
              <% end %>
            </div>
          </div>
        </nav>

        <!-- Sign Out Button -->
        <div class="p-6 border-t border-slate-700">
          <%= link_to destroy_user_session_path, method: :delete, class: "flex items-center justify-center gap-2 w-full px-4 py-2 bg-red-600/20 hover:bg-red-600/30 text-red-400 rounded-lg transition font-medium" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Sign Out
          <% end %>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-auto">
        <!-- Top Bar -->
        <div class="bg-slate-950/50 backdrop-blur border-b border-slate-700 px-8 py-4 sticky top-0 z-10">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="text-2xl font-bold text-white"><%= current_user.full_name %></h2>
              <p class="text-sm text-slate-400"><%= current_user.email %></p>
            </div>
            <%= link_to "← Back to Browse", services_path, class: "px-4 py-2 bg-slate-800 hover:bg-slate-700 text-teal-400 rounded-lg transition font-medium" %>
          </div>
        </div>

        <!-- Flash Messages -->
        <div class="px-8 py-4 space-y-2">
          <% if notice.present? %>
            <div class="p-4 rounded-lg bg-emerald-900/30 text-emerald-400 border border-emerald-700 flex items-center gap-3">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <%= notice %>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="p-4 rounded-lg bg-red-900/30 text-red-400 border border-red-700 flex items-center gap-3">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              <%= alert %>
            </div>
          <% end %>
        </div>

        <!-- Page Content -->
        <div class="px-8 py-8">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>