<div class="max-w-2xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold mb-6">Message <%= @service.user.full_name %></h1>

  <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">
    <h2 class="text-lg font-semibold mb-4"><%= @service.name %></h2>

    <%= form_with model: [@service, @message], local: true do |f| %>
      <div class="space-y-4">
        
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Message</label>
          <%= f.text_area :content, rows: 5, placeholder: "Type your message...", class: "w-full border border-slate-300 rounded-lg px-3 py-2" %>
        </div>

        <div class="flex gap-4">
          <%= f.submit "Send Message", class: "px-6 py-3 bg-emerald-600 text-white rounded-xl hover:bg-emerald-700 transition shadow-sm cursor-pointer" %>
          <%= link_to "Cancel", @service, class: "px-6 py-3 border border-slate-300 rounded-xl hover:bg-slate-50 transition text-center" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
